# Application
LLM_APP_ENV=development
LLM_LOG_LEVEL=debug

# Model
LLM_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0
LLM_DEVICE=cpu
LLM_MAX_NEW_TOKENS=256
LLM_GENERATION_TIMEOUT_S=60.0
LLM_MAX_CONCURRENT_REQUESTS=1

# Redis
LLM_REDIS_URL=redis://localhost:6379/0

# AWS (for production)
AWS_REGION=us-west-2
S3_BUCKET=
CLOUDWATCH_NAMESPACE=MiniLLMServing

# Tracing (these don't use LLM_ prefix — they're OpenTelemetry standard)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=llm-serving
